{
    "manifest_version": 3,
    "name": "GithubPlus",
    "author": "xl1te (lighscent)",
    "version": "1.0.0",
    "description": "Upgrade your github experience",
    "permissions": [
        "scripting"
    ],
    "content_scripts": [
        {
            "matches": [
                "https://github.com/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_end"
        }
    ]
}