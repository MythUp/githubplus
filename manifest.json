{
    "manifest_version": 3,
    "name": "GithubPlus",
    "author": "xl1te (lighscent)",
    "version": "1.1.0",
    "description": "Upgrade your github experience",
    "host_permissions": [
        "https://github.com/*"
    ],
    "content_scripts": [
        {
            "matches": [
                "https://github.com/*"
            ],
            "js": [
                "badges.js",
                "pagination.js"
            ],
            "run_at": "document_end"
        }
    ]
}